# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Required
OPENAI_API_KEY=sk-...

# Optional — defaults shown
OPENAI_MODEL=gpt-4o-mini
ALLOWED_ORIGINS=https://yourexpress.github.io
MAX_INPUT_LENGTH=1000
MAX_CONCURRENT_REQUESTS=10
RATE_LIMIT_BURST=10
RATE_LIMIT_REFILL_INTERVAL=600
TRUST_PROXY_HEADERS=false
APP_VERSION=1.0.0
MAX_HISTORY_MESSAGES=12

# File-backed runtime data (mount these paths to persistent storage in containers)
DATA_DIR=data
SITE_CONTENT_FILE=data/site_content.json
COMMENTS_FILE=data/comments.json

# Manager entrance
ADMIN_API_KEY=replace-with-a-strong-admin-key

# Happy personality mode
HAPPY_MODE_ENABLED=false
HAPPY_MODE_ACCESS_CODE=replace-with-happy-code
HAPPY_MODE_QUESTION=Replace this question in your private server config.
HAPPY_MODE_EXPECTED_ANSWER=replace-with-happy-answer
HAPPY_MODE_SECRET=replace-with-a-random-secret
