# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Required
OPENAI_API_KEY=sk-...

# LLM provider selection
# - auto: infer from model name / base URL
# - openai: official OpenAI API
# - openai_compatible: any OpenAI-compatible endpoint such as Gemini, Groq, DeepSeek, OpenRouter
# - anthropic: Claude via Anthropic Messages API
LLM_PROVIDER=auto

# Model selection
# OPENAI_MODEL is used for OpenAI and OpenAI-compatible providers.
# It is also used as the fallback model name for Anthropic if ANTHROPIC_MODEL is empty.
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512

# Gemini example:
# LLM_PROVIDER=gemini
# OPENAI_API_KEY=your-gemini-key
# OPENAI_MODEL=gemini-2.5-flash
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Anthropic example:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional — defaults shown
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,https://yourexpress.github.io,https://runyuma.uk,https://www.runyuma.uk
MAX_INPUT_LENGTH=1000
MAX_CONCURRENT_REQUESTS=10
RATE_LIMIT_BURST=10
RATE_LIMIT_REFILL_INTERVAL=600
TRUST_PROXY_HEADERS=false
APP_VERSION=1.0.0
MAX_HISTORY_MESSAGES=12

# File-backed runtime data (mount these paths to persistent storage in containers)
DATA_DIR=data
SITE_CONTENT_FILE=data/site_content.json
COMMENTS_FILE=data/comments.json

# Manager entrance
ADMIN_API_KEY=replace-with-a-strong-admin-key

# Happy personality mode
HAPPY_MODE_ENABLED=false
HAPPY_MODE_ACCESS_CODE=replace-with-happy-code
HAPPY_MODE_QUESTION=Replace this question in your private server config.
HAPPY_MODE_EXPECTED_ANSWER=replace-with-happy-answer
# Used only to sign and verify the happy-mode session token after unlock.
HAPPY_MODE_SECRET=replace-with-a-random-secret
HAPPY_MODE_VISITOR_NAME_EN=replace-with-her-english-name
HAPPY_MODE_VISITOR_NAME_ZH=replace-with-her-chinese-name
